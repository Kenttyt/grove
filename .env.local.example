VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional: when the UI is opened from another URL (e.g. static build) but the PHP API
# runs on your PC, set this to that API origin (no trailing slash), e.g.:
# VITE_API_BASE=http://192.168.1.10:8787
VITE_API_BASE=

# Set to true only if you need the #system diagnostics screen in a production build (default: hidden).
# VITE_SHOW_SYSTEM_STATUS=true
